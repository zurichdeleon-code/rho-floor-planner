// CANVAS KEY (new hire legend)
// ═══════════════════════════════════════════════════════
let _keyDrag=null;

function renderKey(){
  const canvas=document.getElementById('floor-canvas');
  const draft=getDraft();
  canvas.querySelector('.canvas-key')?.remove();
  // Sync toggle button state
  const kBtn=document.getElementById('key-toggle-btn');
  if(kBtn) kBtn.classList.toggle('active', !!(draft?.showKey));
  if(!draft?.showKey) return;

  const newHires=draft.desks.filter(d=>d.newHire);
  const key=document.createElement('div');
  key.className='canvas-key';
  key.style.left=(draft.keyPos?.x??20)+'px';
  key.style.top=(draft.keyPos?.y??20)+'px';

  const fmt=dateStr=>{ if(!dateStr)return'—'; const [y,m,d]=dateStr.split('-'); return new Date(+y,+m-1,+d).toLocaleDateString(undefined,{month:'short',day:'numeric',year:'numeric'}); };
  const rows=newHires.length?newHires.map(desk=>{
    const dept=desk.deptId?getDept(desk.deptId):null;
    const dot=desk.color||(dept?dept.color:'#2dd4bf');
    return `<div class="key-row">
      <div class="key-dot" style="background:${dot}"></div>
      <span class="key-name">${escH(desk.name)}</span>
      ${dept?`<span class="key-dept" style="background:${dept.color}">${escH(dept.name)}</span>`:''}
      <span class="key-date">${fmt(desk.startDate)}</span>
    </div>`;
  }).join(''):'<div class="key-empty">No new hires marked yet</div>';

  key.innerHTML=`
    <div class="key-hd" id="_khdl">
      <span class="key-title">🆕 New Hire Key</span>
      <button class="key-close" id="_kclose">✕</button>
    </div>
    <div class="key-body">${rows}</div>`;

  // Drag key header
  key.querySelector('#_khdl').addEventListener('mousedown',e=>{
    if(e.target.matches('.key-close'))return;
    e.preventDefault();
    const kr=key.getBoundingClientRect();
    _keyDrag={ox:e.clientX-kr.left, oy:e.clientY-kr.top};
    document.addEventListener('mousemove',_onKeyDrag);
    document.addEventListener('mouseup',_stopKeyDrag);
  });

  // Close key
  key.querySelector('#_kclose').addEventListener('click',e=>{
    e.stopPropagation();
    draft.showKey=false; save(); renderKey();
  });

  canvas.appendChild(key);
}

function _onKeyDrag(e){
  if(!_keyDrag)return;
  const canvas=document.getElementById('floor-canvas');
  const cr=canvas.getBoundingClientRect();
  const p=canvas.parentElement;
  const key=canvas.querySelector('.canvas-key');
  if(!key)return;
  let x=e.clientX-cr.left-_keyDrag.ox+p.scrollLeft;
  let y=e.clientY-cr.top-_keyDrag.oy+p.scrollTop;
  x=clamp(x,0,Math.max(0,canvas.offsetWidth-key.offsetWidth));
  y=clamp(y,0,Math.max(0,canvas.offsetHeight-key.offsetHeight));
  key.style.left=x+'px'; key.style.top=y+'px';
}

function _stopKeyDrag(){
  if(!_keyDrag)return;
  const canvas=document.getElementById('floor-canvas');
  const key=canvas.querySelector('.canvas-key');
  if(key){ const draft=getDraft(); if(draft){ draft.keyPos={x:parseInt(key.style.left),y:parseInt(key.style.top)}; save(); } }
  _keyDrag=null;
  document.removeEventListener('mousemove',_onKeyDrag);
  document.removeEventListener('mouseup',_stopKeyDrag);
}

// ═══════════════════════════════════════════════════════
// DESK DRAG
// ═══════════════════════════════════════════════════════
function startDeskDrag(e){ if(e.target.matches('.dc-btn'))return; e.preventDefault(); const el=e.currentTarget; const r=el.getBoundingClientRect(); draggingDesk=el; dragOffset={x:e.clientX-r.left,y:e.clientY-r.top}; el.classList.add('selected'); el.style.zIndex=100; document.addEventListener('mousemove',onDeskDrag); document.addEventListener('mouseup',stopDeskDrag); }
function startDeskDragTouch(e){ if(e.target.matches('.dc-btn'))return; e.preventDefault(); const t=e.touches[0]; const el=e.currentTarget; const r=el.getBoundingClientRect(); draggingDesk=el; dragOffset={x:t.clientX-r.left,y:t.clientY-r.top}; el.classList.add('selected'); el.style.zIndex=100; document.addEventListener('touchmove',onDeskDragTouch,{passive:false}); document.addEventListener('touchend',stopDeskDrag); }
function onDeskDrag(e){ moveDeskTo(e.clientX,e.clientY); }
function onDeskDragTouch(e){ e.preventDefault(); moveDeskTo(e.touches[0].clientX,e.touches[0].clientY); }
function moveDeskTo(cx,cy){
  if(!draggingDesk)return;
  const canvas=document.getElementById('floor-canvas');
  const cr=canvas.getBoundingClientRect();
  const p=canvas.parentElement;
  // Desired visual position of the element's top-left corner
  const vx=cx-cr.left-dragOffset.x+p.scrollLeft;
  const vy=cy-cr.top-dragOffset.y+p.scrollTop;
  // transform-origin:top center means the element shrinks symmetrically around its
  // horizontal midpoint, so the visual left drifts right by naturalWidth*(1-scale)/2.
  // We must subtract that drift to get the correct CSS left.
  const scaleM=draggingDesk.style.transform.match(/scale\(([^)]+)\)/);
  const scale=scaleM?parseFloat(scaleM[1]):1;
  const shift=draggingDesk.offsetWidth*(1-scale)/2;
  let x=clamp(vx-shift,0,canvas.offsetWidth-80);
  let y=clamp(vy,0,canvas.offsetHeight-80);
  draggingDesk.style.left=x+'px';
  draggingDesk.style.top=y+'px';
}
function stopDeskDrag(){ if(!draggingDesk)return; const id=+draggingDesk.dataset.id; const desk=getDraft()?.desks.find(d=>d.id===id); if(desk){desk.x=parseInt(draggingDesk.style.left);desk.y=parseInt(draggingDesk.style.top);save();} draggingDesk.style.zIndex=10; draggingDesk.classList.remove('selected'); draggingDesk=null; document.removeEventListener('mousemove',onDeskDrag); document.removeEventListener('mouseup',stopDeskDrag); document.removeEventListener('touchmove',onDeskDragTouch); document.removeEventListener('touchend',stopDeskDrag); }

// ═══════════════════════════════════════════════════════
// DESK CRUD
// ═══════════════════════════════════════════════════════
function addDesk(name){
  if(!name.trim())return;
  const draft=getDraft(); const canvas=document.getElementById('floor-canvas'); const count=draft.desks.length;
  const cols=Math.max(1,Math.floor((canvas.offsetWidth-80)/95));
  const deptId = +document.getElementById('dept-select').value || null;
  const desk={id:nextDeskId++,name:name.trim(),x:20+(count%cols)*95,y:20+Math.floor(count/cols)*95,scale:1,deptId,color:null,newHire:false,startDate:''};
  draft.desks.push(desk);
  canvas.appendChild(mkDeskEl(desk));
  snap(`Added desk "${desk.name}" · ${getOffice().name} / ${getDraft()?.name}`);
  renderPeopleList(); renderTabs(); save();
}

function removeDesk(id){
  const draft=getDraft(); const desk=draft.desks.find(d=>d.id===id);
  if(!desk)return;
  snap(`Removed desk "${desk.name}" · ${getOffice().name} / ${getDraft()?.name}`);
  draft.desks=draft.desks.filter(d=>d.id!==id);
  const el=document.querySelector(`.desk-icon[data-id="${id}"]`);
  if(el){el.style.transition='opacity .15s,transform .15s';el.style.opacity='0';el.style.transform='scale(0.7)';setTimeout(()=>el.remove(),160);}
  renderPeopleList(); renderTabs(); save();
}

function highlightDesk(id){ const el=document.querySelector(`.desk-icon[data-id="${id}"]`); if(!el)return; el.scrollIntoView({behavior:'smooth',block:'nearest'}); el.classList.add('selected'); setTimeout(()=>el.classList.remove('selected'),1500); }
function switchOffice(id){ currentOfficeId=id; save(); renderAll(); }

// ═══════════════════════════════════════════════════════
// BACKGROUND
// ═══════════════════════════════════════════════════════
function initDragDrop(){
  const canvas=document.getElementById('floor-canvas');
  canvas.addEventListener('dragenter',e=>{e.preventDefault();canvas.classList.add('drag-over');});
  canvas.addEventListener('dragover',e=>e.preventDefault());
  canvas.addEventListener('dragleave',e=>{if(!canvas.contains(e.relatedTarget))canvas.classList.remove('drag-over');});
  canvas.addEventListener('drop',e=>{e.preventDefault();canvas.classList.remove('drag-over');const f=e.dataTransfer.files[0];if(f?.type.startsWith('image/'))loadBg(f);});
}

function loadBg(file){
  const reader=new FileReader();
  reader.onload=e=>{
    const img=new Image();
    img.onload=()=>{
      const MAX=1920;
      const scale=Math.min(1,MAX/Math.max(img.width,img.height));
      const w=Math.round(img.width*scale), h=Math.round(img.height*scale);
      const cv=document.createElement('canvas'); cv.width=w; cv.height=h;
      cv.getContext('2d').drawImage(img,0,0,w,h);
      const compressed=cv.toDataURL('image/jpeg',0.85);
      const d=getDraft(); d.background=compressed; d.bgZoom=100;
      snap(`Updated background · ${getOffice().name} / ${d.name}`); renderCanvas(); save();
    };
    img.src=e.target.result;
  };
  reader.readAsDataURL(file);
}

// ═══════════════════════════════════════════════════════
// EXPORT / IMPORT
// ═══════════════════════════════════════════════════════
function exportData(officeId=null){
  const payload=officeId?{offices:[getOffice(officeId)],single:true,exportedAt:new Date().toISOString()}:{offices:OFFICES,single:false,exportedAt:new Date().toISOString()};
  const a=Object.assign(document.createElement('a'),{href:URL.createObjectURL(new Blob([JSON.stringify(payload,null,2)],{type:'application/json'})),download:officeId?`rho-floor-${officeId}.json`:'rho-floor-plan.json'});
  a.click(); URL.revokeObjectURL(a.href);
}

function importData(file){
  const reader=new FileReader();
  reader.onload=e=>{
    try{
      const data=JSON.parse(e.target.result);
      const offices=data.offices||[];
      if(!offices.length)throw new Error('No offices found');
      if(data.single){ const src=offices[0],dst=getOffice(); Object.assign(dst,src); }
      else offices.forEach((s,i)=>{if(OFFICES[i])Object.assign(OFFICES[i],s);});
      snap('Imported layout from file'); save(); renderAll(); closeModal(); toast('Imported successfully ✓');
    }catch(err){alert('Could not import: '+err.message);}
  };
  reader.readAsText(file);
}

// ═══════════════════════════════════════════════════════
// TOAST
// ═══════════════════════════════════════════════════════
function toast(msg){ const t=Object.assign(document.createElement('div'),{className:'toast',textContent:msg}); document.body.appendChild(t); setTimeout(()=>{t.style.opacity='0';setTimeout(()=>t.remove(),300);},2200); }

// ═══════════════════════════════════════════════════════
// MODAL
// ═══════════════════════════════════════════════════════
const openModal  = ()=>document.getElementById('modal-overlay').classList.add('open');
const closeModal = ()=>{ document.getElementById('modal-overlay').classList.remove('open'); document.getElementById('import-area').classList.remove('vis'); };

// ═══════════════════════════════════════════════════════
// INIT CONTROLS
// ═══════════════════════════════════════════════════════
function initControls(){
  // Login
  document.getElementById('login-btn').addEventListener('click',doLogin);
  document.getElementById('login-input').addEventListener('keydown',e=>{ if(e.key==='Enter')doLogin(); });

  // User chip → change name
  document.getElementById('user-chip').addEventListener('click',()=>{
    const n=prompt('Change your name:',currentUser); if(n?.trim()){currentUser=n.trim();saveUser();updateUserChip();}
  });

  // History
  document.getElementById('history-btn').addEventListener('click',openHistory);
  document.getElementById('close-history').addEventListener('click',closeHistory);
  document.getElementById('history-backdrop').addEventListener('click',closeHistory);

  // Departments
  document.getElementById('add-dept-btn').addEventListener('click', addDept);
  document.getElementById('dept-select').addEventListener('change', updateDeptSelectSwatch);
  document.addEventListener('click',e=>{ if(!e.target.closest('#dept-picker')&&!e.target.matches('.dept-dot')) closeDeptPicker(); });

  // Add desk
  const ni=document.getElementById('name-input');
  document.getElementById('add-btn').addEventListener('click',()=>{addDesk(ni.value);ni.value='';ni.focus();});
  ni.addEventListener('keydown',e=>{if(e.key==='Enter'){addDesk(ni.value);ni.value='';}});

  // BG upload
  const bgf=document.getElementById('bg-file-input');
  document.getElementById('upload-bg-btn').addEventListener('click',()=>bgf.click());
  bgf.addEventListener('change',e=>{if(e.target.files[0])loadBg(e.target.files[0]);bgf.value='';});

  document.getElementById('clear-bg-btn').addEventListener('click',()=>{ const d=getDraft(); if(!d.background)return; snap(`Cleared background · ${getOffice().name} / ${d.name}`); d.background=null; renderCanvas(); save(); });
  document.getElementById('clear-desks-btn').addEventListener('click',()=>{ if(!confirm('Remove all desks from this draft?'))return; snap(`Cleared all desks · ${getOffice().name} / ${getDraft()?.name}`); getDraft().desks=[]; renderCanvas(); renderPeopleList(); renderTabs(); save(); });

  // New hire key toggle
  document.getElementById('key-toggle-btn').addEventListener('click',()=>{
    const draft=getDraft(); if(!draft)return;
    draft.showKey=!draft.showKey; save(); renderKey();
  });

  // BG zoom
  document.getElementById('bg-zoom-slider').addEventListener('input',e=>{
    const v=+e.target.value; document.getElementById('bg-zoom-val').textContent=v+'%';
    const d=getDraft(); d.bgZoom=v; const img=document.querySelector('.bg-img'); if(img)applyBgZoom(img,v); save();
  });

  // Export/Share
  document.getElementById('export-btn').addEventListener('click',()=>exportData());
  document.getElementById('share-btn').addEventListener('click',openModal);
  document.getElementById('modal-close').addEventListener('click',closeModal);
  document.getElementById('modal-overlay').addEventListener('click',e=>{if(e.target===e.currentTarget)closeModal();});
  document.getElementById('opt-all').addEventListener('click',()=>{exportData();closeModal();});
  document.getElementById('opt-office').addEventListener('click',()=>{exportData(currentOfficeId);closeModal();});
  document.getElementById('opt-import').addEventListener('click',()=>document.getElementById('import-area').classList.toggle('vis'));
  document.getElementById('trigger-import').addEventListener('click',()=>document.getElementById('import-json-input').click());
  document.getElementById('import-json-input').addEventListener('change',e=>{if(e.target.files[0])importData(e.target.files[0]);e.target.value='';});

  // Close icon picker on outside click
  document.addEventListener('click',e=>{ if(!e.target.closest('#icon-picker')&&!e.target.matches('.tab-color-btn')) document.getElementById('icon-picker').classList.remove('open'); });
}

// ═══════════════════════════════════════════════════════
// BOOT
// ═══════════════════════════════════════════════════════
load(); loadHistory(); loadUser();
renderAll(); initDragDrop(); initControls(); renderHistory(); updateUserChip();

// Show login if no user
if(!currentUser){ document.getElementById('login-overlay').style.display='flex'; }
else { document.getElementById('login-overlay').classList.add('gone'); }
</script>
</body>
