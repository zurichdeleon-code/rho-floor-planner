// DESK ELEMENT
// ═══════════════════════════════════════════════════════
function mkDeskEl(desk){
  const el=document.createElement('div');
  el.className='desk-icon';
  el.dataset.id=desk.id;
  el.style.left=desk.x+'px'; el.style.top=desk.y+'px';
  el.style.transform=`scale(${desk.scale||1})`; el.style.transformOrigin='top center';
  const dept = desk.deptId ? getDept(desk.deptId) : null;
  const dc  = desk.color||(dept ? dept.color : '#2dd4bf');
  const dcl = desk.color?lighten(desk.color,0.3):(dept ? lighten(dept.color, 0.3) : '#5eead4');
  el.style.setProperty('--dc', dc);
  el.style.setProperty('--dc-l', dcl);
  el.innerHTML=`
    <div class="desk-body">
      ${desk.newHire?'<div class="desk-new-badge">NEW</div>':''}
      <div class="desk-person"></div>
      <div class="desk-surface"><span class="desk-label">${escH(desk.name)}</span></div>
    </div>
    <div class="desk-controls">
      <div class="dc-btn" data-action="shrink" title="Shrink">−</div>
      <div class="dc-btn" data-action="grow" title="Grow">＋</div>
      <div class="dc-btn dept" data-action="settings" title="Desk settings">⚙</div>
      <div class="dc-btn del" data-action="del" title="Remove">✕</div>
    </div>`;
  el.querySelectorAll('.dc-btn').forEach(btn=>{
    btn.addEventListener('mousedown',e=>e.stopPropagation());
    btn.addEventListener('click',e=>{
      e.stopPropagation(); const a=btn.dataset.action;
      if(a==='del'){removeDesk(desk.id);return;}
      if(a==='settings'){openDeskSettings(e,desk,el);return;}
      const step=.15;
      if(a==='shrink')desk.scale=clamp((desk.scale||1)-step,.4,2.5);
      if(a==='grow')desk.scale=clamp((desk.scale||1)+step,.4,2.5);
      el.style.transform=`scale(${desk.scale})`; save();
    });
  });
  el.addEventListener('mousedown',startDeskDrag);
  el.addEventListener('touchstart',startDeskDragTouch,{passive:false});
  return el;
}

