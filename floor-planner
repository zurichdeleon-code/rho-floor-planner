// RENDER: DRAFT BAR
// ═══════════════════════════════════════════════════════
function renderDraftBar(){
  const bar=document.getElementById('draft-bar');
  bar.innerHTML='';
  const office=getOffice();
  office.drafts.forEach(draft=>{
    const tab=document.createElement('div');
    tab.className=`draft-tab${draft.id===office.activeDraftId?' active':''}`;
    tab.dataset.id=draft.id;
    tab.innerHTML=`
      <span class="draft-tab-name">${escH(draft.name)}</span>
      ${office.drafts.length>1?`<button class="draft-del" data-id="${draft.id}" title="Delete">✕</button>`:''}`;
    tab.querySelector('.draft-tab-name').addEventListener('dblclick',e=>{ e.stopPropagation(); startRenameDraft(tab,office,draft); });
    tab.addEventListener('click',e=>{ if(e.target.matches('.draft-del,.draft-tab-inp'))return; switchDraft(draft.id); });
    tab.querySelector('.draft-del')?.addEventListener('click',e=>{ e.stopPropagation(); deleteDraft(draft.id); });
    bar.appendChild(tab);
  });
  if(office.drafts.length<6){
    const btn=document.createElement('button');
    btn.className='btn-new-draft'; btn.textContent='＋ New Draft';
    btn.addEventListener('click',addDraft);
    bar.appendChild(btn);
  }
}

function startRenameDraft(tab,office,draft){
  const span=tab.querySelector('.draft-tab-name');
  const inp=document.createElement('input');
  inp.className='draft-tab-inp'; inp.value=draft.name; inp.maxLength=20;
  span.replaceWith(inp); inp.focus(); inp.select();
  const done=()=>{ const v=inp.value.trim()||draft.name; if(v!==draft.name){draft.name=v;snap(`Renamed draft to "${v}"`);save();} renderDraftBar(); };
  inp.addEventListener('blur',done);
  inp.addEventListener('keydown',e=>{ if(e.key==='Enter')inp.blur(); if(e.key==='Escape'){inp.value=draft.name;inp.blur();} });
  inp.addEventListener('click',e=>e.stopPropagation());
}

function addDraft(){
  const office=getOffice();
  const id=office.nextDraftId++;
  const name=DRAFT_NAMES[office.drafts.length%DRAFT_NAMES.length]||`Option ${office.drafts.length+1}`;
  office.drafts.push(mkDraft(id,name));
  office.activeDraftId=id;
  snap(`Added draft "${name}" to ${office.name}`); save(); renderDraftBar(); renderCanvas(); renderPeopleList(); renderTabs();
}

function deleteDraft(id){
  const office=getOffice();
  if(office.drafts.length<=1)return;
  const draft=office.drafts.find(d=>d.id===id);
  if(!confirm(`Delete draft "${draft?.name}"?`))return;
  snap(`Deleted draft "${draft?.name}" from ${office.name}`);
  office.drafts=office.drafts.filter(d=>d.id!==id);
  if(office.activeDraftId===id) office.activeDraftId=office.drafts[0].id;
  save(); renderDraftBar(); renderCanvas(); renderPeopleList(); renderTabs();
}

function switchDraft(id){ getOffice().activeDraftId=id; save(); renderDraftBar(); renderCanvas(); renderPeopleList(); renderTabs(); renderDepts(); }

