<script>
// ═══════════════════════════════════════════════════════
// CONSTANTS
// ═══════════════════════════════════════════════════════
const COLOR_OPTIONS = [
  {hex:'#3b82f6',name:'Blue'},
  {hex:'#8b5cf6',name:'Purple'},
  {hex:'#22c55e',name:'Green'},
  {hex:'#eab308',name:'Yellow'},
  {hex:'#f97316',name:'Orange'},
];
const DEPT_COLORS = [
  '#ef4444','#f97316','#eab308','#84cc16',
  '#22c55e','#14b8a6','#3b82f6','#8b5cf6',
  '#ec4899','#64748b','#0891b2','#a16207',
];
const DRAFT_NAMES  = ['Option A','Option B','Option C','Option D','Option E','Option F'];

// Lighten a hex color by mixing with white
function lighten(hex,amt=0.35){
  const r=parseInt(hex.slice(1,3),16),g=parseInt(hex.slice(3,5),16),b=parseInt(hex.slice(5,7),16);
  const f=(c)=>Math.round(c+(255-c)*amt).toString(16).padStart(2,'0');
  return '#'+f(r)+f(g)+f(b);
}
let nextDeptId = 1;

// ═══════════════════════════════════════════════════════
// STATE
// ═══════════════════════════════════════════════════════
function mkDraft(id, name){ return {id,name:name||'Option A',desks:[],background:null,bgZoom:100,departments:[],showKey:false,keyPos:{x:20,y:20}}; }
function mkOffice(id){ return {id,name:`Floor ${id}`,color:COLOR_OPTIONS[(id-1)%COLOR_OPTIONS.length].hex,nextDraftId:2,activeDraftId:1,drafts:[mkDraft(1,'Option A')]}; }

const OFFICES = [mkOffice(1),mkOffice(2),mkOffice(3),mkOffice(4)];
let currentOfficeId = 1;
let nextDeskId = 1;
let currentUser = '';
let historyLog = [];

// Drag state
let draggingDesk = null, dragOffset = {x:0,y:0};
let sortState = null; // office reorder drag

// ═══════════════════════════════════════════════════════
// HELPERS
// ═══════════════════════════════════════════════════════
const getOffice = (id=currentOfficeId) => OFFICES.find(o=>o.id===id);
const getDraft  = (o=getOffice())      => o?.drafts.find(d=>d.id===o.activeDraftId);
const clamp     = (v,a,b)             => Math.max(a,Math.min(v,b));
const escH      = t                   => String(t).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
const fmtTime   = iso => { const d=new Date(iso); return d.toLocaleDateString()+' '+d.toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'}); };
const initials  = name => name.split(' ').map(w=>w[0]).join('').slice(0,2).toUpperCase()||'?';

function save(){
  try{ localStorage.setItem('rho_fp_v2',JSON.stringify({OFFICES,currentOfficeId,nextDeskId,nextDeptId})); }catch(e){}
}
function load(){
  try{
    const raw=localStorage.getItem('rho_fp_v2');
    if(!raw)return;
    const s=JSON.parse(raw);
    s.OFFICES?.forEach((so,i)=>{ if(OFFICES[i]){ Object.assign(OFFICES[i],so); so.drafts?.forEach(d=>{if(d.id>=OFFICES[i].nextDraftId)OFFICES[i].nextDraftId=d.id+1;}); }});
    if(s.currentOfficeId) currentOfficeId=s.currentOfficeId;
    if(s.nextDeskId) nextDeskId=s.nextDeskId;
    if(s.nextDeptId) nextDeptId=s.nextDeptId;
  }catch(e){}
}
function saveHistory(){ try{ localStorage.setItem('rho_fp_hist',JSON.stringify(historyLog)); }catch(e){} }
function loadHistory(){ try{ const r=localStorage.getItem('rho_fp_hist'); if(r) historyLog=JSON.parse(r); }catch(e){} }

// ═══════════════════════════════════════════════════════
// SNAPSHOT / HISTORY
// ═══════════════════════════════════════════════════════
function snap(action){
  const entry={
    id:Date.now(), at:new Date().toISOString(), user:currentUser||'Unknown', action,
    officeOrder: OFFICES.map(o=>o.id),
    data: JSON.parse(JSON.stringify(OFFICES.map(o=>({...o,drafts:o.drafts.map(d=>({...d,background:'__bg__'}))})))),
    currentOfficeId, nextDeskId
  };
  historyLog.unshift(entry);
  if(historyLog.length>30) historyLog.length=30;
  saveHistory();
  renderHistory();
}

function restoreSnap(id){
  const entry=historyLog.find(h=>h.id===id);
  if(!entry)return;
  if(!confirm(`Restore to "${entry.action}"?\nCurrent layout will be replaced (backgrounds kept).`))return;

  // Keep existing backgrounds
  const bgMap={};
  OFFICES.forEach(o=>o.drafts.forEach(d=>{ bgMap[`${o.id}-${d.id}`]=d.background; }));

  // Reorder OFFICES to match snapshot
  const oMap=Object.fromEntries(OFFICES.map(o=>[o.id,o]));
  OFFICES.length=0;
  entry.officeOrder.forEach(id=>{ if(oMap[id]) OFFICES.push(oMap[id]); });

  // Restore data (preserve backgrounds)
  entry.data.forEach(saved=>{
    const office=OFFICES.find(o=>o.id===saved.id);
    if(!office)return;
    Object.assign(office,saved);
    office.drafts.forEach(d=>{ const bg=bgMap[`${office.id}-${d.id}`]; if(bg&&bg!=='__bg__') d.background=bg; else if(d.background==='__bg__') d.background=null; });
  });

  currentOfficeId=entry.currentOfficeId;
  nextDeskId=entry.nextDeskId;
  save(); renderAll(); closeHistory(); toast(`Restored: "${entry.action}"`);
}

function renderHistory(){
  const list=document.getElementById('history-list');
  if(!historyLog.length){ list.innerHTML='<div class="history-empty">No history yet</div>'; return; }
  list.innerHTML='';
  historyLog.forEach(entry=>{
    const el=document.createElement('div');
    el.className='h-entry';
    el.innerHTML=`
      <div class="h-entry-top">
        <span class="h-entry-action">${escH(entry.action)}</span>
        <button class="h-restore" data-id="${entry.id}">Restore</button>
      </div>
      <div class="h-entry-meta">
        <span class="h-user"><span class="h-avatar">${escH(initials(entry.user))}</span>${escH(entry.user)}</span>
        <span class="h-time">${fmtTime(entry.at)}</span>
      </div>`;
    el.querySelector('.h-restore').addEventListener('click',()=>restoreSnap(entry.id));
    list.appendChild(el);
  });
}

const openHistory  = ()=>{ document.getElementById('history-drawer').classList.add('open'); document.getElementById('history-backdrop').classList.add('open'); renderHistory(); };
const closeHistory = ()=>{ document.getElementById('history-drawer').classList.remove('open'); document.getElementById('history-backdrop').classList.remove('open'); };

// ═══════════════════════════════════════════════════════
// LOGIN
// ═══════════════════════════════════════════════════════
function loadUser(){ currentUser=localStorage.getItem('rho_fp_user')||''; }
function saveUser(){ localStorage.setItem('rho_fp_user',currentUser); }

function doLogin(){
  const val=document.getElementById('login-input').value.trim();
  if(!val)return;
  currentUser=val; saveUser(); updateUserChip();
  document.getElementById('login-overlay').classList.add('gone');
}

function updateUserChip(){
  document.getElementById('user-label').textContent=currentUser||'You';
  document.getElementById('user-avatar').textContent=initials(currentUser||'?');
}

// ═══════════════════════════════════════════════════════
// RENDER: ALL
// ═══════════════════════════════════════════════════════
function renderAll(){ renderTabs(); renderDraftBar(); renderCanvas(); renderPeopleList(); renderDepts(); }

// ═══════════════════════════════════════════════════════
// RENDER: OFFICE TABS
// ═══════════════════════════════════════════════════════
function renderTabs(){
  const container=document.getElementById('office-tabs');
  // Keep sort-line, remove old tabs
  container.querySelectorAll('.office-tab').forEach(e=>e.remove());
  OFFICES.forEach(office=>{
    const count=getDraft(office)?.desks.length||0;
    const tab=document.createElement('div');
    tab.className=`office-tab${office.id===currentOfficeId?' active':''}`;
    tab.dataset.id=office.id;
    tab.innerHTML=`
      <span class="drag-handle" data-id="${office.id}" title="Drag to reorder">⠿</span>
      <span class="tab-color-btn" data-id="${office.id}" title="Change color" style="background:${escH(office.color||COLOR_OPTIONS[0].hex)}"></span>
      <span class="tab-name-wrap">${escH(office.name)}</span>
      <button class="tab-edit-btn" data-id="${office.id}" title="Rename">✏️</button>
      <span class="tab-count">${count}</span>`;

    tab.addEventListener('click',e=>{
      if(e.target.matches('.drag-handle,.tab-color-btn,.tab-edit-btn,.tab-rename-inp'))return;
      switchOffice(office.id);
    });
    tab.querySelector('.tab-edit-btn').addEventListener('click',e=>{ e.stopPropagation(); startRenameOffice(tab,office); });
    tab.querySelector('.tab-name-wrap').addEventListener('dblclick',e=>{ e.stopPropagation(); startRenameOffice(tab,office); });
    tab.querySelector('.tab-color-btn').addEventListener('click',e=>{ e.stopPropagation(); openIconPicker(e,office); });
    tab.querySelector('.drag-handle').addEventListener('mousedown',e=>{ e.stopPropagation(); startOfficeSort(e,office); });
    container.appendChild(tab);
  });
}

function startRenameOffice(tab,office){
  const span=tab.querySelector('.tab-name-wrap');
  const editBtn=tab.querySelector('.tab-edit-btn');
  const inp=document.createElement('input');
  inp.className='tab-rename-inp'; inp.value=office.name; inp.maxLength=24;
  span.replaceWith(inp); editBtn.style.opacity='0'; inp.focus(); inp.select();
  const done=()=>{ const v=inp.value.trim()||office.name; if(v!==office.name){office.name=v;snap(`Renamed office to "${v}"`);save();} renderTabs(); };
  inp.addEventListener('blur',done);
  inp.addEventListener('keydown',e=>{ if(e.key==='Enter')inp.blur(); if(e.key==='Escape'){inp.value=office.name;inp.blur();} });
  inp.addEventListener('click',e=>e.stopPropagation());
}

// ── Office reorder drag ──────────────────────────────
function startOfficeSort(e,office){
  e.preventDefault();
  sortState={id:office.id,startY:e.clientY,currentInsert:null};
  document.getElementById('office-tabs').querySelector(`[data-id="${office.id}"].office-tab`)?.classList.add('drag-ghost');
  document.addEventListener('mousemove',onOfficeSort);
  document.addEventListener('mouseup',stopOfficeSort);
}

function onOfficeSort(e){
  if(!sortState)return;
  const tabs=[...document.getElementById('office-tabs').querySelectorAll('.office-tab:not(.drag-ghost)')];
  let insertBefore=null;
  for(const tab of tabs){
    const r=tab.getBoundingClientRect();
    if(e.clientY<r.top+r.height/2){ insertBefore=+tab.dataset.id; break; }
  }
  sortState.currentInsert=insertBefore;
  // Show indicator line
  const line=document.getElementById('sort-line');
  if(insertBefore!==null){
    const target=tabs.find(t=>+t.dataset.id===insertBefore);
    if(target){ const r=target.getBoundingClientRect(); const cr=document.getElementById('office-tabs').getBoundingClientRect(); line.style.top=(r.top-cr.top)+'px'; line.style.display='block'; }
  } else {
    const last=tabs[tabs.length-1];
    if(last){ const r=last.getBoundingClientRect(); const cr=document.getElementById('office-tabs').getBoundingClientRect(); line.style.top=(r.bottom-cr.top)+'px'; line.style.display='block'; }
  }
}

function stopOfficeSort(){
  if(!sortState)return;
  const {id,currentInsert}=sortState;
  const idx=OFFICES.findIndex(o=>o.id===id);
  if(idx>=0){
    const [office]=OFFICES.splice(idx,1);
    if(currentInsert!==null){ const ti=OFFICES.findIndex(o=>o.id===currentInsert); OFFICES.splice(ti,0,office); }
    else OFFICES.push(office);
  }
  document.getElementById('sort-line').style.display='none';
  sortState=null;
  document.removeEventListener('mousemove',onOfficeSort);
  document.removeEventListener('mouseup',stopOfficeSort);
  snap('Reordered offices'); save(); renderTabs();
}

// ═══════════════════════════════════════════════════════
// ICON PICKER
// ═══════════════════════════════════════════════════════
let pickerOffice=null;
function openIconPicker(e,office){
  pickerOffice=office;
  const picker=document.getElementById('icon-picker');
  picker.innerHTML=`<div class="ip-picker-label">Office color</div><div class="ip-swatches"></div>`;
  const swatchWrap=picker.querySelector('.ip-swatches');
  COLOR_OPTIONS.forEach(col=>{
    const btn=document.createElement('div');
    btn.className=`ip-swatch${col.hex===office.color?' selected':''}`;
    btn.style.background=col.hex;
    btn.title=col.name;
    btn.addEventListener('click',()=>{ office.color=col.hex; snap(`Changed color for "${office.name}" to ${col.name}`); save(); renderTabs(); closePicker(); });
    swatchWrap.appendChild(btn);
  });
  const r=e.target.getBoundingClientRect();
  picker.style.top=(r.bottom+6)+'px';
  picker.style.left=r.left+'px';
  picker.classList.add('open');
  setTimeout(()=>document.addEventListener('click',closePicker,{once:true}),0);
}
function closePicker(){ document.getElementById('icon-picker').classList.remove('open'); pickerOffice=null; }

// ═══════════════════════════════════════════════════════
// DEPARTMENTS
// ═══════════════════════════════════════════════════════
function getDepts(){ return getDraft()?.departments || []; }
function getDept(id){ return getDepts().find(d=>d.id===id); }

function renderDepts(){
  const draft = getDraft();
  const depts = draft?.departments || [];
  const list = document.getElementById('dept-list');
  list.innerHTML = '';

  if(!depts.length){
    list.innerHTML='<div class="dept-empty">No departments yet</div>';
  } else {
    depts.forEach(dept=>{
      const item = document.createElement('div');
      item.className = 'dept-item';
      item.innerHTML=`
        <span class="dept-dot" style="background:${escH(dept.color)}" title="Change color" data-id="${dept.id}"></span>
        <span class="dept-name" data-id="${dept.id}">${escH(dept.name)}</span>
        <button class="dept-del" data-id="${dept.id}" title="Delete">✕</button>`;
      item.querySelector('.dept-dot').addEventListener('click',e=>{ e.stopPropagation(); openDeptPicker(e,dept); });
      item.querySelector('.dept-name').addEventListener('dblclick',e=>{ e.stopPropagation(); startRenameDept(item,dept); });
      item.querySelector('.dept-del').addEventListener('click',e=>{ e.stopPropagation(); deleteDept(dept.id); });
      list.appendChild(item);
    });
  }
  populateDeptSelect();
}

function addDept(){
  const draft = getDraft(); if(!draft) return;
  if(!draft.departments) draft.departments=[];
  const color = DEPT_COLORS[draft.departments.length % DEPT_COLORS.length];
  const dept = {id: nextDeptId++, name:'New Department', color};
  draft.departments.push(dept);
  save(); renderDepts();
  // Auto-rename immediately
  const items = document.querySelectorAll('.dept-item');
  const last = items[items.length-1];
  if(last) startRenameDept(last, dept);
}

function deleteDept(id){
  const draft = getDraft(); if(!draft) return;
  const dept = draft.departments.find(d=>d.id===id);
  if(!confirm(`Delete "${dept?.name}"? Desks in this department will lose their color.`)) return;
  draft.departments = draft.departments.filter(d=>d.id!==id);
  // Unassign desks
  draft.desks.forEach(desk=>{ if(desk.deptId===id) desk.deptId=null; });
  snap(`Deleted department "${dept?.name}"`);
  save(); renderDepts(); renderCanvas(); renderPeopleList();
}

function startRenameDept(item, dept){
  const span = item.querySelector('.dept-name');
  const inp = document.createElement('input');
  inp.className='dept-name-inp'; inp.value=dept.name; inp.maxLength=24;
  span.replaceWith(inp); inp.focus(); inp.select();
  const done=()=>{
    const v=inp.value.trim()||dept.name;
    dept.name=v; save(); renderDepts();
  };
  inp.addEventListener('blur',done);
  inp.addEventListener('keydown',e=>{ if(e.key==='Enter')inp.blur(); if(e.key==='Escape'){inp.value=dept.name;inp.blur();} });
  inp.addEventListener('click',e=>e.stopPropagation());
}

// Dept color picker
let activeDeptForPicker=null;
function openDeptPicker(e,dept){
