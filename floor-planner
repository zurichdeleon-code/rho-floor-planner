function renderCanvas(){
  const canvas=document.getElementById('floor-canvas');
  const hint=document.getElementById('drop-hint');
  const draft=getDraft();
  canvas.querySelectorAll('.desk-icon').forEach(d=>d.remove());
  if(!draft)return;

  let bgImg=canvas.querySelector('.bg-img');
  if(draft.background){
    if(!bgImg){ bgImg=document.createElement('img'); bgImg.className='bg-img'; bgImg.draggable=false; canvas.insertBefore(bgImg,canvas.firstChild); }
    bgImg.src=draft.background; applyBgZoom(bgImg,draft.bgZoom);
    hint.classList.add('hidden'); showBgZoom(true,draft.bgZoom);
  } else {
    bgImg?.remove(); hint.classList.remove('hidden'); showBgZoom(false);
  }
  draft.desks.forEach(desk=>canvas.appendChild(mkDeskEl(desk)));
  renderKey();
}

function applyBgZoom(img,zoom){ img.style.transform=`scale(${zoom/100})`; img.style.transformOrigin='center center'; }
function showBgZoom(vis,val=100){
  const w=document.getElementById('bg-zoom-wrap');
  w.classList.toggle('vis',vis);
  if(vis){ document.getElementById('bg-zoom-slider').value=val; document.getElementById('bg-zoom-val').textContent=val+'%'; }
